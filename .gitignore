# ---- 密钥 / 本地配置（含大模型 API Key，绝不入库）----
.env

# ---- Python ----
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# ---- 本地数据缓存（行情 parquet、交易日历）----
# 注意：前导 / 锚定到仓库根目录，只忽略根目录的 data/ 缓存，
# 不能写成 data/（那会连源码包 quant/data/ 一起忽略掉）。
/data/

# ---- 前端 ----
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
# TypeScript 构建产物（由 tsc -b 生成，不应提交）
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# ---- IDE / 系统 ----
.idea/
.vscode/
.DS_Store
