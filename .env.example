# AI 智能分析配置（复制本文件为 .env 并填入你的 Key；.env 已被 gitignore，不会入库）
#
# 默认走 DeepSeek。换其他 OpenAI 兼容服务（豆包/通义/OpenAI 等）只需改下面三个值。

# 必填：DeepSeek API Key（在 https://platform.deepseek.com 申请）
DEEPSEEK_API_KEY=

# 可选：接入点与模型（不填则用 DeepSeek 默认值）
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# ---- 换成豆包（火山方舟）示例 ----
# LLM_API_KEY=你的火山方舟Key
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=你的推理接入点ID或模型名
